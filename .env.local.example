# ─── Clerk auth ───
# Get these at https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=<your-clerk-publishable-key>
CLERK_SECRET_KEY=<your-clerk-secret-key>

# Tell Clerk where the auth pages live so its components redirect correctly.
# Auth pages live on the dashboard subdomain — the middleware enforces that.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup

# After auth, land users on the dashboard subdomain root ("/").
# The middleware rewrites that to /dashboard internally so URLs stay clean.
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
